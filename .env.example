# Copy to .env and fill in your values.
# .env is gitignored — never commit it.
# On Unraid set these in the Docker UI instead.

# ── Plex tokens ───────────────────────────────────────────────────────────────
# One per instance, named after the instance name in the wizard:
# uppercased, spaces/hyphens → underscores, prefixed PLEX_TOKEN_
# Example: "My Plex" → PLEX_TOKEN_MY_PLEX=xxxxx
PLEX_TOKEN_MY_INSTANCE=your_plex_token_here
# PLEX_TOKEN_MY_OTHER_INSTANCE=your_other_token_here

# ── Debrid provider API keys (optional) ───────────────────────────────────────
RD_API_KEY=your_realdebrid_api_key
# AD_API_KEY=your_alldebrid_api_key
# TB_API_KEY=your_torbox_api_key
# DL_API_KEY=your_debridlink_api_key

# ── Web UI auth (optional) ────────────────────────────────────────────────────
# If set, the web UI requires username/password login.
# Leave blank to disable auth.
# EMPTYARR_USERNAME=admin
# EMPTYARR_PASSWORD=changeme

# ── Notifications ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your/webhook

# ── Other ─────────────────────────────────────────────────────────────────────
PUID=99
PGID=100
TZ=America/New_York
# LOG_LEVEL=INFO
# EMPTYARR_SECRET_KEY=  # Set to a stable random value (e.g. `openssl rand -hex 32`)
#                       # Without this, sessions are invalidated on every container restart.
# BROWSE_ROOTS=/mnt,/media,/data,/home  # Comma-separated list of roots the file browser may enter
