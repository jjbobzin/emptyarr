# emptyarr configuration example
# Copy this to config.yml and edit to match your setup.
# The setup wizard at http://YOUR_IP:8222 can generate this for you.

discord_webhook: https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

notify:
  on_emptied: true       # notify when trash was actually emptied
  on_health_fail: true   # notify when health checks failed and empty was skipped
  on_error: true         # notify when emptyTrash API call failed
  on_clean: false        # notify when run succeeded but trash was already empty (noisy)
  on_skip: false         # notify when run was skipped (scheduling paused, config error)

# Optional: set username/password to protect the web UI
# Leave out to disable auth (fine for trusted local networks)
# Or configure via Settings → Security in the UI
auth:
  username: admin
  password_hash: ""  # set via Settings UI — never enter plaintext here

# Optional: debrid provider API keys for health checks
# Can also be set as env vars: RD_API_KEY, AD_API_KEY, TB_API_KEY, DL_API_KEY
# Or configure via Settings → Providers in the UI
# providers:
#   realdebrid:
#     api_key: YOUR_RD_API_KEY

plex_instances:
  # Physical media server example
  - name: My Plex
    url: http://192.168.1.100:32400
    token: ""  # set via PLEX_TOKEN_STREAMSTEAD env var, or paste in Settings UI
    libraries:
      - name: Movies
        type: physical
        cron: "0 * * * *"   # every hour — standard cron syntax
        paths:
          - path: /mnt/user/media/movies
            type: physical
            min_threshold: 90  # 90% of Plex count must exist on disk

      - name: TV Shows
        type: physical
        cron: "0 * * * *"
        paths:
          - path: /mnt/user/media/tv
            type: physical
            min_threshold: 90

      - name: Sports
        type: physical
        cron: "0 * * * *"
        paths:
          - path: /mnt/user/media/sports
            type: physical
            min_threshold: 50  # lower threshold for small/growing libraries

  # Debrid media server example
  - name: My Plex Unlimited
    url: http://192.168.1.100:32410
    token: ""  # set via PLEX_TOKEN_STREAMSTEAD_UNLIMITED env var
    libraries:
      # Mixed library — physical usenet + debrid symlinks in same Plex library
      # threshold check combines all paths vs total Plex count
      - name: Movies
        type: mixed
        cron: "*/30 * * * *"  # every 30 minutes
        paths:
          - path: /mnt/user/media/movies
            type: physical
            min_threshold: 90
          - path: /symlink_media/symlinks/radarr
            type: debrid
            min_threshold: 90
            provider_checks:
              - type: realdebrid
                api_key: ""  # uses RD_API_KEY env var or providers block above

      # Pure debrid library
      - name: TV Shows
        type: debrid
        cron: "*/30 * * * *"
        paths:
          - path: /symlink_media/symlinks/sonarr
            type: debrid
            min_threshold: 90
            provider_checks:
              - type: realdebrid
                api_key: ""
